# Auth0 Configuration
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_AUDIENCE=your-api-audience

# Token Vault Configuration
TOKEN_VAULT_URL=https://your-tenant.auth0.com/api/v2/token-vault
TOKEN_VAULT_CLIENT_ID=your-vault-client-id
TOKEN_VAULT_CLIENT_SECRET=your-vault-client-secret

# AI Configuration (Choose ONE - Both are optional for demo mode)
# Option 1: Groq (FREE - 14,400 requests/day) - Get from https://console.groq.com
GROQ_API_KEY=

# Option 2: OpenAI (Paid) - Get from https://platform.openai.com
OPENAI_API_KEY=

# Server Configuration
PORT=3001
CLIENT_URL=http://localhost:5173
